# Porta de execução do Servidor Express
PORT=5000

# MODO SIMULADO / FALLBACK RESILIENTE (Recomendado para testar instantaneamente todas as curvas de gráficos e alertas)
# Defina como "true" para usar oscilações históricas simuladas inteligentes.
# Defina como "false" para acionar o motor real do Playwright.
MOCK_SCRAPING=true

# ALERTA DISCORD (Cole a URL de integração de Webhook do seu canal)
DISCORD_WEBHOOK_URL=

# ALERTA TELEGRAM
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ALERTA WHATSAPP (Estrutura modular pronta para conexão de gateway comercial)
WHATSAPP_API_URL=
WHATSAPP_TARGET_PHONE=
